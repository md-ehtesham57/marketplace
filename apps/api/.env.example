PORT=4000
NODE_ENV=development
CLIENT_URL=http://localhost:3000

# Database — create a dedicated role (not superuser):
#   CREATE ROLE marketplace_app WITH LOGIN PASSWORD '...' CONNECTION LIMIT 10;
#   GRANT SELECT, INSERT, UPDATE, DELETE ON ALL TABLES IN SCHEMA public TO marketplace_app;
# Production: add ?sslmode=require for encrypted connections
DATABASE_URL="postgresql://marketplace_app:password@localhost:5432/marketplace?connect_timeout=10"

# Generate a strong secret: openssl rand -hex 64
JWT_SECRET=change_this_to_a_random_secret # openssl rand -hex 64
